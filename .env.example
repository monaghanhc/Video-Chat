# Signaling server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173
TRUST_PROXY=false
COOKIE_SECURE=false
DATABASE_PATH=./data/deskcall.db

# Auth (generate unique random strings >= 32 chars for production)
JWT_ACCESS_SECRET=dev-access-secret-change-before-production-32
JWT_REFRESH_SECRET=dev-refresh-secret-change-before-production-32
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
AUTH_MODE=optional

# Rate limits
ROOM_RATE_LIMIT_WINDOW_MS=60000
ROOM_RATE_LIMIT_MAX=20
ROOM_JOIN_RATE_LIMIT_MAX=30
SOCKET_EVENT_RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=15

# Desktop renderer default; users can override this inside the app settings.
VITE_SIGNALING_SERVER_URL=http://localhost:4000
DESKCALL_SIGNALING_SERVER_URL=http://localhost:4000

# Optional TURN support for tougher NATs in production.
VITE_TURN_URLS=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
