{
  "name": "@deskcall/desktop",
  "version": "0.1.0-beta.4",
  "description": "Windows-first private video chat desktop app",
  "author": "DeskCall",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n renderer,electron-watch,electron-app -c blue,yellow,green \"npm run dev:renderer\" \"npm run dev:electron:watch\" \"npm run dev:electron:app\"",
    "dev:renderer": "vite --host 0.0.0.0",
    "dev:electron:watch": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron:app": "wait-on http://localhost:5173 file:dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview:web": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "package:windows": "npm run build && electron-builder --win nsis",
    "start": "electron ."
  },
  "dependencies": {
    "@deskcall/shared": "0.1.0",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "cross-env": "^10.1.0",
    "electron": "42.1.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.13",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.deskcall.app",
    "productName": "DeskCall",
    "artifactName": "DeskCall-Setup-${version}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DeskCall"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.social-networking"
    }
  }
}
